<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>See All Posts </title>
    <link rel="stylesheet" href="index.css">
</head>
<body>
    <h1>Quora Posts</h1>
    <br>
    <br>
    <br>
    <br>
    <% for(post of posts) { %>
        <div class="pundu">
            <h3> Username : @<%= post.username %></h3>
            <br>
            <h4>Content : <%= post.content %><h4>
            <br>
            <br>
            <a href="http://localhost:3000/posts/<%=post.id %>">Show In Detail</a>
            &nbsp;&nbsp; &nbsp;&nbsp; &nbsp;&nbsp;
            <a href="http://localhost:3000/posts/<%=post.id %>/edit">Edit Post</a>
            &nbsp;&nbsp; &nbsp;&nbsp; &nbsp;&nbsp;
            <br><br>
            <form action="/posts/<%=post.id%>?_method=DELETE" method="post">
                <button>Delete Post </button>
            </form>
        </div>
        <% } %>
        <br><br>
        <br><br>
        <a href="http://localhost:3000/posts/new"> Create New Post </a>
</body>
</html>